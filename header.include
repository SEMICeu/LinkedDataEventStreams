<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>[TITLE]</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style data-fill-with="stylesheet"></style>
  <style>
    :root {
      --semic-blue: #005ea8;
      --semic-text: #1f1f1f;
      --semic-muted: #555;
      --semic-border: #d9d9d9;
    }

    body {
      color: var(--semic-text);
    }

    a {
      color: var(--semic-blue);
    }

    .head {
      border-bottom: 1px solid var(--semic-border);
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
    }

    .head h1 {
      color: var(--heading-text);
      letter-spacing: 0;
    }

    .head h2 {
      color: var(--semic-muted);
    }

    .head hr {
      display: none;
    }

    .head .logo {
      float: right;
      margin: 0.2rem 0 1rem 1.5rem;
    }

    #semic-logo {
      display: block;
      height: auto;
      max-width: 154px;
    }

    .ldes-document-logo {
      margin: 1.5rem 0;
      text-align: center;
    }

    .ldes-document-logo img {
      display: block;
      height: auto;
      margin: 0 auto;
      max-width: 180px;
    }

    .ldes-vocabulary-diagram {
      margin: 2rem 0;
      text-align: center;
    }

    .ldes-vocabulary-diagram img {
      height: auto;
      max-width: 100%;
    }

    .ldes-vocabulary-diagram figcaption {
      color: var(--semic-muted);
      font-size: 0.9rem;
      margin-top: 0.5rem;
    }

    .head dl {
      margin-top: 1rem;
    }

    .head dt {
      color: var(--semic-muted);
    }

    .ldes-version-nav {
      border-top: 1px solid var(--semic-border);
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      margin-top: 1rem;
      padding-top: 1rem;
    }

    .ldes-version-nav a {
      font-size: 0.95rem;
    }

    .ldes-version-nav a[hidden] {
      display: none;
    }

    .semic-footer {
      border-top: 1px solid var(--semic-border);
      color: var(--semic-muted);
      font-size: 0.9rem;
      margin-top: 3rem;
      padding-top: 1rem;
    }
  </style>
  <!-- Matomo -->
  <script bs-macros include-if="text macro: SEMICMATOMOID">
    var _paq = window._paq = window._paq || [];
    /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
    _paq.push(['trackPageView']);
    _paq.push(['enableLinkTracking']);
    (function() {
      var u="//health.semic.eu/matomo/";
      _paq.push(['setTrackerUrl', u+'matomo.php']);
      _paq.push(['setSiteId', '[SEMICMATOMOID?]']);
      var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
      g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
    })();
  </script>
  <!-- End Matomo Code -->
  <script>
    (() => {
      const siteBase = "https://semiceu.github.io/LinkedDataEventStreams/";
      const releasesBase = `${siteBase}releases/`;
      const workingDraftBase = `${siteBase}workingdraft/`;

      const currentPath = new URL(window.location.href).pathname;
      const releaseMatch = currentPath.match(/\/releases\/([^/]+)\/([^?#]*)?$/);
      const documentName = (() => {
        const lastSegment = currentPath.split("/").filter(Boolean).pop() || "";
        if (!lastSegment || !lastSegment.endsWith(".html")) return "index.html";
        return lastSegment;
      })();

      const documentPath = documentName === "index.html" ? "" : documentName;
      const linkTargets = {
        latest: `${siteBase}${documentPath}`,
        workingDraft: `${workingDraftBase}${documentPath}`,
      };

      async function urlExists(url) {
        try {
          const response = await fetch(url, { method: "HEAD" });
          return response.ok;
        } catch {
          return false;
        }
      }

      async function getReleases() {
        try {
          const response = await fetch(releasesBase);
          if (!response.ok) return [];
          const html = await response.text();
          return [...html.matchAll(/href="([^"]+)\/"/g)]
            .map((match) => decodeURIComponent(match[1]))
            .filter((release) => release && release !== "assets");
        } catch {
          return [];
        }
      }

      async function setVersionLinks() {
        const nav = document.querySelector(".ldes-version-nav");
        if (!nav) return;

        const latest = nav.querySelector('[data-version-link="latest"]');
        const workingDraft = nav.querySelector('[data-version-link="working-draft"]');
        latest.href = linkTargets.latest;
        workingDraft.href = linkTargets.workingDraft;

        if (!(await urlExists(linkTargets.workingDraft))) {
          workingDraft.hidden = true;
        }

        if (!releaseMatch) return;

        const currentRelease = decodeURIComponent(releaseMatch[1]);
        const releases = await getReleases();
        const currentIndex = releases.indexOf(currentRelease);
        if (currentIndex === -1) return;

        const previous = nav.querySelector('[data-version-link="previous"]');
        const next = nav.querySelector('[data-version-link="next"]');
        const candidates = [
          [previous, releases[currentIndex + 1]],
          [next, releases[currentIndex - 1]],
        ];

        for (const [link, release] of candidates) {
          if (!release) continue;
          const href = `${releasesBase}${encodeURIComponent(release)}/${documentPath}`;
          if (await urlExists(href)) {
            link.href = href;
            link.hidden = false;
          }
        }
      }

      window.addEventListener("DOMContentLoaded", setVersionLinks);
    })();
  </script>
</head>
<body class="h-entry">
  <div class="head">
    <p data-fill-with="logo"></p>
    <h1 id="title" class="p-name no-ref">[SPECTITLE]</h1>
    <h2 id="profile-and-date" class="no-num no-toc no-ref heading">
      <time class="dt-updated" datetime="[ISODATE]">[DATE]</time>
    </h2>
    <div data-fill-with="spec-metadata"></div>
    <div data-fill-with="warning"></div>
    <p class="copyright" data-fill-with="copyright"></p>
    <nav class="ldes-version-nav" aria-label="Version navigation">
      <a href="#" data-version-link="previous" hidden>Previous version</a>
      <a href="#" data-version-link="next" hidden>Next version</a>
      <a href="#" data-version-link="latest">Latest version</a>
      <a href="#" data-version-link="working-draft">Working draft</a>
    </nav>
  </div>
  <section class="p-summary" data-fill-with="abstract"></section>
  <div data-fill-with="at-risk"></div>
  <nav data-fill-with="table-of-contents" id="toc"></nav>
  <main>
