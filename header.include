<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>[TITLE]</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style data-fill-with="stylesheet"></style>
  <style>
    :root {
      --semic-blue: #005ea8;
      --semic-text: #1f1f1f;
      --semic-muted: #555;
      --semic-border: #d9d9d9;
    }

    body {
      color: var(--semic-text);
    }

    a {
      color: var(--semic-blue);
    }

    .head {
      border-bottom: 1px solid var(--semic-border);
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
    }

    .head h1 {
      color: var(--heading-text);
      letter-spacing: 0;
    }

    .head h2 {
      color: var(--semic-muted);
    }

    .head hr {
      display: none;
    }

    .head .logo {
      float: right;
      margin: 0.2rem 0 1rem 1.5rem;
    }

    #semic-logo {
      display: block;
      height: auto;
      max-width: 154px;
    }

    .ldes-document-logo {
      margin: 1.5rem 0;
      text-align: center;
    }

    .ldes-document-logo img {
      display: block;
      height: auto;
      margin: 0 auto;
      max-width: 180px;
    }

    .ldes-vocabulary-diagram {
      margin: 2rem 0;
      text-align: center;
    }

    .ldes-vocabulary-diagram img {
      height: auto;
      max-width: 100%;
    }

    .ldes-vocabulary-diagram figcaption {
      color: var(--semic-muted);
      font-size: 0.9rem;
      margin-top: 0.5rem;
    }

    .head dl {
      margin-top: 1rem;
    }

    .head dt {
      color: var(--semic-muted);
    }

    .ldes-version-links [hidden] {
      display: none;
    }

    .semic-footer {
      border-top: 1px solid var(--semic-border);
      color: var(--semic-muted);
      font-size: 0.9rem;
      margin-top: 3rem;
      padding-top: 1rem;
    }
  </style>
  <!-- Matomo -->
  <script bs-macros include-if="text macro: SEMICMATOMOID">
    var _paq = window._paq = window._paq || [];
    /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
    _paq.push(['trackPageView']);
    _paq.push(['enableLinkTracking']);
    (function() {
      var u="//health.semic.eu/matomo/";
      _paq.push(['setTrackerUrl', u+'matomo.php']);
      _paq.push(['setSiteId', '[SEMICMATOMOID?]']);
      var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
      g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
    })();
  </script>
  <!-- End Matomo Code -->
  <script>
    (() => {
      const siteBase = "https://semiceu.github.io/LinkedDataEventStreams/";
      const releasesBase = `${siteBase}releases/`;
      const workingDraftBase = `${siteBase}workingdraft/`;

      const currentPath = new URL(window.location.href).pathname;
      const releaseMatch = currentPath.match(/\/releases\/([^/]+)\/([^?#]*)?$/);
      const documentName = (() => {
        const lastSegment = currentPath.split("/").filter(Boolean).pop() || "";
        if (!lastSegment || !lastSegment.endsWith(".html")) return "index.html";
        return lastSegment;
      })();

      const documentPath = documentName === "index.html" ? "" : documentName;
      const linkTargets = {
        latest: `${siteBase}${documentPath}`,
        workingDraft: `${workingDraftBase}${documentPath}`,
      };

      async function urlExists(url) {
        try {
          const response = await fetch(url, { method: "HEAD" });
          return response.ok;
        } catch {
          return false;
        }
      }

      async function getReleases() {
        try {
          const response = await fetch(releasesBase);
          if (!response.ok) return [];
          const html = await response.text();
          return [...html.matchAll(/href="([^"]+)\/"/g)]
            .map((match) => decodeURIComponent(match[1]))
            .filter((release) => release && release !== "assets");
        } catch {
          return [];
        }
      }

      async function setVersionLinks() {
        const versionLinks = buildVersionRows();
        if (!versionLinks) return;

        const currentUrl = new URL(window.location.href);
        currentUrl.hash = "";
        currentUrl.search = "";

        const thisVersion = versionLinks.querySelector('[data-version-link="this-version"]');
        const latest = versionLinks.querySelector('[data-version-link="latest"]');
        const workingDraft = versionLinks.querySelector('[data-version-link="working-draft"]');

        thisVersion.href = currentUrl.toString();
        thisVersion.textContent = currentUrl.toString();
        latest.href = linkTargets.latest;
        latest.textContent = linkTargets.latest;
        workingDraft.href = linkTargets.workingDraft;
        workingDraft.textContent = linkTargets.workingDraft;

        if (!(await urlExists(linkTargets.workingDraft))) {
          setVersionRowVisibility("working-draft", true);
        }

        if (!releaseMatch) return;

        const currentRelease = decodeURIComponent(releaseMatch[1]);
        const releases = await getReleases();
        const currentIndex = releases.indexOf(currentRelease);
        if (currentIndex === -1) return;

        const previous = versionLinks.querySelector('[data-version-link="previous"]');
        const next = versionLinks.querySelector('[data-version-link="next"]');
        const candidates = [
          [previous, releases[currentIndex + 1]],
          [next, releases[currentIndex - 1]],
        ];

        for (const [link, release] of candidates) {
          if (!release) continue;
          const href = `${releasesBase}${encodeURIComponent(release)}/${documentPath}`;
          if (await urlExists(href)) {
            link.href = href;
            link.textContent = href;
            setVersionRowVisibility(link.dataset.versionLink, false);
          }
        }
      }

      function buildVersionRows() {
        const metadata = document.querySelector('[data-fill-with="spec-metadata"] dl');
        if (!metadata) return null;
        metadata.classList.add("ldes-version-links");

        const thisTerm = findMetadataTerm(metadata, "This version:") || createTerm("This version:");
        if (!thisTerm.parentElement) {
          metadata.prepend(thisTerm, createDefinition("this-version"));
        }

        const thisDefinition = getRowDefinitions(thisTerm)[0] || createDefinition("this-version");
        if (!thisDefinition.parentElement) {
          thisTerm.after(thisDefinition);
        }

        const thisLink = thisDefinition.querySelector("a") || document.createElement("a");
        thisLink.dataset.versionLink = "this-version";
        if (!thisLink.parentElement) {
          thisDefinition.replaceChildren(thisLink);
        }

        const previousRow = createVersionRow("previous", "Previous version:", true);
        const nextRow = createVersionRow("next", "Next version:", true);
        const latestRow = createVersionRow("latest", "Latest version:", false);
        const workingDraftRow = createVersionRow("working-draft", "Working draft:", false);

        thisTerm.before(...previousRow);
        getRowEnd(thisTerm).after(...nextRow, ...latestRow, ...workingDraftRow);

        return metadata;
      }

      function createVersionRow(linkName, label, hidden) {
        const term = createTerm(label, linkName, hidden);
        const definition = createDefinition(linkName, hidden);
        return [term, definition];
      }

      function createTerm(label, linkName, hidden = false) {
        const term = document.createElement("dt");
        term.textContent = label;
        if (linkName) {
          term.dataset.versionRow = linkName;
        }
        term.hidden = hidden;
        return term;
      }

      function createDefinition(linkName, hidden = false) {
        const definition = document.createElement("dd");
        const link = document.createElement("a");
        link.href = "#";
        link.dataset.versionLink = linkName;
        definition.dataset.versionRow = linkName;
        definition.hidden = hidden;
        definition.append(link);
        return definition;
      }

      function findMetadataTerm(metadata, label) {
        return [...metadata.querySelectorAll("dt")]
          .find((term) => term.textContent.trim() === label);
      }

      function getRowDefinitions(term) {
        const definitions = [];
        for (let node = term.nextElementSibling; node && node.tagName.toLowerCase() === "dd"; node = node.nextElementSibling) {
          definitions.push(node);
        }
        return definitions;
      }

      function getRowEnd(term) {
        const definitions = getRowDefinitions(term);
        return definitions[definitions.length - 1] || term;
      }

      function setVersionRowVisibility(linkName, hidden) {
        document
          .querySelectorAll(`[data-version-row="${linkName}"]`)
          .forEach((element) => {
            element.hidden = hidden;
          });
      }

      window.addEventListener("DOMContentLoaded", setVersionLinks);
    })();
  </script>
</head>
<body class="h-entry">
  <div class="head">
    <p data-fill-with="logo"></p>
    <h1 id="title" class="p-name no-ref">[SPECTITLE]</h1>
    <h2 id="profile-and-date" class="no-num no-toc no-ref heading">
      <time class="dt-updated" datetime="[ISODATE]">[DATE]</time>
    </h2>
    <div data-fill-with="spec-metadata"></div>
    <div data-fill-with="warning"></div>
    <p class="copyright" data-fill-with="copyright"></p>
  </div>
  <section class="p-summary" data-fill-with="abstract"></section>
  <div data-fill-with="at-risk"></div>
  <nav data-fill-with="table-of-contents" id="toc"></nav>
  <main>
